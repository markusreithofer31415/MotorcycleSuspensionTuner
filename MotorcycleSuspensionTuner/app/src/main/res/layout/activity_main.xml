<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".MainActivity">

    <TextView
        android:id="@+id/textViewCharacteristicVibration"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Characteristic Vibration: N/A"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="16dp"/>

    <com.github.mikephil.charting.charts.LineChart
        android:id="@+id/lineChartVibrations"
        android:layout_width="0dp"
        android:layout_height="200dp"
        app:layout_constraintTop_toBottomOf="@id/textViewCharacteristicVibration"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="16dp"
        android:layout_marginStart="16dp"
        android:layout_marginEnd="16dp"/>

    <TextView
        android:id="@+id/textViewCurrentSuspensionSettings"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Current Suspension Settings"
        app:layout_constraintTop_toBottomOf="@id/lineChartVibrations"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="16dp"/>

    <TextView
        android:id="@+id/textViewCurrentRebound"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Rebound: N/A"
        app:layout_constraintTop_toBottomOf="@id/textViewCurrentSuspensionSettings"
        app:layout_constraintStart_toStartOf="parent"
        android:layout_marginStart="16dp"
        android:layout_marginTop="8dp"/>

    <TextView
        android:id="@+id/textViewCurrentCompression"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Compression: N/A"
        app:layout_constraintTop_toBottomOf="@id/textViewCurrentSuspensionSettings"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginEnd="16dp"
        android:layout_marginTop="8dp"/>

    <TextView
        android:id="@+id/textViewRecommendedAdjustments"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Recommended Adjustments"
        app:layout_constraintTop_toBottomOf="@id/textViewCurrentRebound"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="16dp"/>

    <TextView
        android:id="@+id/textViewRecommendedRebound"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Rebound: N/A"
        app:layout_constraintTop_toBottomOf="@id/textViewRecommendedAdjustments"
        app:layout_constraintStart_toStartOf="parent"
        android:layout_marginStart="16dp"
        android:layout_marginTop="8dp"/>

    <TextView
        android:id="@+id/textViewRecommendedCompression"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Compression: N/A"
        app:layout_constraintTop_toBottomOf="@id/textViewRecommendedAdjustments"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginEnd="16dp"
        android:layout_marginTop="8dp"/>

    <Button
        android:id="@+id/buttonStartStopTestRide"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Start Test Ride"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginBottom="16dp"/>

</androidx.constraintlayout.widget.ConstraintLayout>
