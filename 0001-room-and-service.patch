@@ -0,0 +1,28 @@
+package com.example.motorcyclesuspensiontuner.data
+
+import android.content.Context
+
+class DataRepository(context: Context) {
+  private val db = AppDatabase.get(context)
+  private val runDao = db.runDao()
+  private val windowDao = db.windowDao()
+
+  suspend fun startRun(
+    bikeName: String? = null,
+    mountPosition: String? = null,
+    clicksRebound: Int? = null,
+    clicksCompression: Int? = null,
+    preload: Float? = null,
+    notes: String? = null
+  ): Long {
+    val run = RunEntity(
+      startedAtMs = System.currentTimeMillis(),
+      bikeName = bikeName, mountPosition = mountPosition,
+      clicksRebound = clicksRebound, clicksCompression = clicksCompression,
+      preload = preload, notes = notes
+    )
+    return runDao.insert(run)
+  }
+
+  suspend fun insertWindow(win: WindowEntity) = windowDao.insert(win)
+}
diff --git a/MotorcycleSuspensionTuner/app/src/main/java/com/example/motorcyclesuspensiontuner/sensing/SensorForegroundService.kt b/MotorcycleSuspensionTuner/app/src/main/java/com/example/motorcyclesuspensiontuner/sensing/SensorForegroundService.kt
new file mode 100644
index 0000000..9999999
--- /dev/null
+++ b/MotorcycleSuspensionTuner/app/src/main/java/com/example/motorcyclesuspensiontuner/sensing/SensorForegroundService.kt
@@ -0,0 +1,232 @@
+package com.example.motorcyclesuspensiontuner.sensing
+
+import android.app.Notification
+import android.app.NotificationChannel
+import android.app.NotificationManager
+import android.app.Service
+import android.content.Context
+import android.content.Intent
+import android.hardware.Sensor
+import android.hardware.SensorEvent
+import android.hardware.SensorEventListener
+import android.hardware.SensorManager
+import android.os.Build
+import android.os.IBinder
+import androidx.core.app.NotificationCompat
+import androidx.core.content.getSystemService
+import com.example.motorcyclesuspensiontuner.data.DataRepository
+import com.example.motorcyclesuspensiontuner.data.WindowEntity
+import kotlinx.coroutines.CoroutineScope
+import kotlinx.coroutines.Dispatchers
+import kotlinx.coroutines.Job
+import kotlinx.coroutines.delay
+import kotlinx.coroutines.launch
+import java.util.concurrent.ConcurrentLinkedQueue
+import kotlin.math.sqrt
+
+/**
+ * Foreground-Service, der Beschleunigungsdaten erfasst und als
+ * Fenster-Metriken (RMS Z) in Room schreibt.
+ *
+ * V1: Gerätekordinaten (Z), Rotation/Gravitation folgen im nächsten Schritt.
+ */
+class SensorForegroundService : Service(), SensorEventListener {
+
+  companion object {
+    const val ACTION_START = "com.example.motorcyclesuspensiontuner.action.START_RUN"
+    const val ACTION_STOP  = "com.example.motorcyclesuspensiontuner.action.STOP_RUN"
+    private const val CHANNEL_ID = "measurements"
+    private const val NOTIF_ID = 1001
+  }
+
+  private val scope = CoroutineScope(Dispatchers.Default)
+  private var repo: DataRepository? = null
+  private var sensorManager: SensorManager? = null
+  private var accelerometer: Sensor? = null
+
+  // Ringpuffer: (timestampMs, z)
+  private val buffer = ConcurrentLinkedQueue<Pair<Long, Float>>()
+
+  // Aggregator-Job (schreibt Fenster in DB)
+  private var windowJob: Job? = null
+  private var currentRunId: Long? = null
+
+  override fun onBind(intent: Intent?): IBinder? = null
+
+  override fun onCreate() {
+    super.onCreate()
+    repo = DataRepository(this)
+    sensorManager = getSystemService()
+    accelerometer = sensorManager?.getDefaultSensor(Sensor.TYPE_ACCELEROMETER)
+    createNotificationChannel()
+  }
+
+  override fun onStartCommand(intent: Intent?, flags: Int, startId: Int): Int {
+    when (intent?.action) {
+      ACTION_START -> startRun()
+      ACTION_STOP  -> stopRun()
+      else -> { /* ignore */ }
+    }
+    return START_STICKY
+  }
+
+  private fun startRun() {
+    if (currentRunId != null) return // läuft schon
+
+    // Foreground-Notification
+    val notif = NotificationCompat.Builder(this, CHANNEL_ID)
+      .setContentTitle("Suspension Tuner")
+      .setContentText("Messung läuft …")
+      .setSmallIcon(android.R.drawable.ic_media_play)
+      .setOngoing(true)
+      .build()
+    startForeground(NOTIF_ID, notif)
+
+    scope.launch {
+      currentRunId = repo?.startRun(mountPosition = null)
+    }
+    // Sensor-Listener registrieren (≈200 Hz; mit Batching)
+    accelerometer?.also { acc ->
+      val sm = sensorManager ?: return
+      val samplingUs = 5000 // ~200 Hz
+      val maxLatencyUs = 100_000 // 100 ms Batch
+      sm.registerListener(this, acc, samplingUs, maxLatencyUs)
+    }
+    // Aggregation: alle 100 ms ein 250-ms-Fenster schreiben
+    windowJob = scope.launch {
+      while (true) {
+        val now = System.currentTimeMillis()
+        val from = now - 250
+        val win = buffer.filter { it.first in from..now }
+        val rmsZ = computeRmsZ(win)
+        val runId = currentRunId
+        if (runId != null && !rmsZ.isNaN()) {
+          repo?.insertWindow(WindowEntity(
+            runId = runId,
+            tStartMs = from,
+            tEndMs = now,
+            rmsZ = rmsZ
+          ))
+        }
+        cleanupOld(now - 1000) // Puffer kurz halten
+        delay(100) // 10 Hz
+      }
+    }
+  }
+
+  private fun stopRun() {
+    windowJob?.cancel()
+    windowJob = null
+    sensorManager?.unregisterListener(this)
+    buffer.clear()
+    currentRunId = null
+    stopForeground(STOP_FOREGROUND_DETACH)
+    stopSelf()
+  }
+
+  override fun onDestroy() {
+    stopRun()
+    super.onDestroy()
+  }
+
+  override fun onSensorChanged(event: SensorEvent?) {
+    if (event?.sensor?.type != Sensor.TYPE_ACCELEROMETER) return
+    val ts = System.currentTimeMillis()
+    val z = event.values[2] // V1: Gerätez-Achse
+    buffer.add(ts to z)
+  }
+
+  override fun onAccuracyChanged(sensor: Sensor?, accuracy: Int) = Unit
+
+  private fun computeRmsZ(samples: List<Pair<Long, Float>>): Double {
+    if (samples.isEmpty()) return Double.NaN
+    var sumSq = 0.0
+    for ((_, z) in samples) {
+      sumSq += (z * z).toDouble()
+    }
+    return sqrt(sumSq / samples.size)
+  }
+
+  private fun cleanupOld(cutoffMs: Long) {
+    while (true) {
+      val head = buffer.peek() ?: break
+      if (head.first < cutoffMs) buffer.poll() else break
+    }
+  }
+
+  private fun createNotificationChannel() {
+    if (Build.VERSION.SDK_INT >= Build.VERSION_CODES.O) {
+      val nm = getSystemService(Context.NOTIFICATION_SERVICE) as NotificationManager
+      val ch = NotificationChannel(CHANNEL_ID, "Measurements",
+        NotificationManager.IMPORTANCE_LOW)
+      ch.description = "Laufende Fahrwerksmessungen"
+      nm.createNotificationChannel(ch)
+    }
+  }
+}
