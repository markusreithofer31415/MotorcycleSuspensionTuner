+package com.example.motorcyclesuspensiontuner.data
+
+import androidx.room.Dao
+import androidx.room.Insert
+import androidx.room.OnConflictStrategy
+import androidx.room.Query
+import kotlinx.coroutines.flow.Flow
+
+@Dao
+interface WindowDao {
+  @Insert(onConflict = OnConflictStrategy.REPLACE)
+  suspend fun insert(win: WindowEntity): Long
+
+  @Query("SELECT * FROM windows WHERE runId = :runId ORDER BY tStartMs ASC")
+  fun windowsForRun(runId: Long): Flow<List<WindowEntity>>
+
+  @Query("DELETE FROM windows WHERE runId = :runId")
+  suspend fun deleteForRun(runId: Long)
+}
